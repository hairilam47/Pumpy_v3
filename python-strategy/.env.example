# Python Strategy Engine Environment Variables
# Copy to .env and adjust values

ENVIRONMENT=development

# gRPC connection to Rust engine
GRPC_HOST=localhost
GRPC_PORT=50051

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8001

# Redis (optional, for caching/pub-sub)
REDIS_URL=redis://localhost:6379

# Strategies
SNIPER_ENABLED=true
MOMENTUM_ENABLED=true
ML_ENABLED=true

# Sniper settings
SNIPER_BUY_AMOUNT_SOL=0.05
SNIPER_SLIPPAGE_BPS=500
SNIPER_MAX_MARKET_CAP_SOL=100.0
SNIPER_MIN_LIQUIDITY_SOL=1.0

# Momentum settings
MOMENTUM_BUY_AMOUNT_SOL=0.1
MOMENTUM_SLIPPAGE_BPS=300
MOMENTUM_VOLUME_THRESHOLD=10.0
MOMENTUM_PRICE_CHANGE_THRESHOLD=0.05
MOMENTUM_WINDOW_SECONDS=300

# ML model
ML_MODEL_PATH=models/signal_model.pkl
ML_CONFIDENCE_THRESHOLD=0.65
ML_FEATURE_WINDOW=50

# Risk management
MAX_POSITION_SIZE_SOL=1.0
MAX_PORTFOLIO_EXPOSURE_SOL=10.0
MAX_DAILY_LOSS_SOL=2.0
STOP_LOSS_PERCENTAGE=0.20
TAKE_PROFIT_PERCENTAGE=0.50
