# PumpFun Trading Engine - Environment Variables
# Copy this file to .env and fill in your values

# ─── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── Solana RPC ────────────────────────────────────────────────────────────────
# Primary RPC endpoint (Helius, QuickNode, or public)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# WebSocket endpoint for real-time event monitoring
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
# RPC provider name (for logging)
RPC_PROVIDER=public

# ─── Wallet ────────────────────────────────────────────────────────────────────
# Path to your Solana wallet keypair JSON file (array of bytes)
KEYPAIR_PATH=keypair.json

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pumpfun

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server Ports ──────────────────────────────────────────────────────────────
# gRPC server port (Python strategy engine connects here)
GRPC_PORT=50051
# Prometheus metrics port
METRICS_PORT=9091

# ─── MEV Protection ────────────────────────────────────────────────────────────
MEV_PROTECTION_ENABLED=true
# Jito bundle endpoint (leave empty to disable Jito)
JITO_BUNDLE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
# Maximum sandwich risk score (0-100, orders above this are rejected)
MAX_SANDWICH_RISK_SCORE=70

# ─── Risk Limits ───────────────────────────────────────────────────────────────
# Maximum SOL per single position
MAX_POSITION_SIZE_SOL=1.0
# Maximum total portfolio exposure in SOL
MAX_PORTFOLIO_EXPOSURE_SOL=10.0
# Maximum daily loss before trading halts
MAX_DAILY_LOSS_SOL=2.0
# Maximum allowed slippage in basis points (100 = 1%)
MAX_SLIPPAGE_BPS=500

# ─── Trading Parameters ────────────────────────────────────────────────────────
DEFAULT_SLIPPAGE_BPS=100
MIN_TRADE_SIZE_SOL=0.01
MAX_TRADE_SIZE_SOL=1.0
# Jito tip as fraction of trade value
TIP_PERCENTAGE=0.001
RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000

# ─── Execution ─────────────────────────────────────────────────────────────────
# Number of parallel execution workers
EXECUTION_WORKERS=4
MAX_CONCURRENT_ORDERS=10
ORDER_TIMEOUT_SECONDS=30

# ─── Monitoring ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Optional: Slack webhook for alerts
SLACK_WEBHOOK_URL=
