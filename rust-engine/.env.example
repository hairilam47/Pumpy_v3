# PumpFun Trading Engine - Environment Variables
# Copy this file to .env and fill in your values.
# [REQUIRED] variables will cause the engine to abort on startup if missing.
# [OPTIONAL] variables have safe defaults.

# ─── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development                         # [OPTIONAL] development | production

# ─── Wallet [REQUIRED] ─────────────────────────────────────────────────────────
# Path to your Solana wallet keypair JSON file (array of 64 bytes).
# Generate with: solana-keygen new --outfile keypair.json
KEYPAIR_PATH=keypair.json                       # [REQUIRED]

# ─── Database [REQUIRED] ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pumpfun  # [REQUIRED]

# ─── Solana RPC ────────────────────────────────────────────────────────────────
# Single-endpoint (simplest setup):
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com   # [OPTIONAL] used if SOLANA_RPC_URLS not set
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com      # [OPTIONAL] used if SOLANA_WS_URLS not set

# Multi-endpoint (recommended for production — comma-separated, same index across all lists):
# SOLANA_RPC_URLS=https://mainnet.helius-rpc.com/?api-key=KEY,https://api.mainnet-beta.solana.com
# SOLANA_WS_URLS=wss://mainnet.helius-rpc.com/?api-key=KEY,wss://api.mainnet-beta.solana.com
# RPC_PRIORITIES=1,2          # Lower = higher priority; defaults to positional order (1,2,...)
# RPC_PROVIDERS=helius,public  # Human-readable names; auto-detected from URL if not set

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379               # [OPTIONAL]

# ─── Server Ports ──────────────────────────────────────────────────────────────
GRPC_PORT=50051                               # [OPTIONAL] gRPC server port
METRICS_PORT=9091                             # [OPTIONAL] Prometheus metrics port

# ─── MEV Protection / Jito ─────────────────────────────────────────────────────
MEV_PROTECTION_ENABLED=true                   # [OPTIONAL]
# Leave JITO_BUNDLE_URL empty to disable Jito (engine falls back to direct RPC).
JITO_BUNDLE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles  # [OPTIONAL]
MAX_SANDWICH_RISK_SCORE=70                    # [OPTIONAL] 0–100; orders above this score are rejected

# ─── Risk Limits ───────────────────────────────────────────────────────────────
MAX_POSITION_SIZE_SOL=1.0                     # [OPTIONAL]
MAX_PORTFOLIO_EXPOSURE_SOL=10.0               # [OPTIONAL]
MAX_DAILY_LOSS_SOL=2.0                        # [OPTIONAL]
MAX_SLIPPAGE_BPS=500                          # [OPTIONAL] 100 bps = 1%

# ─── Trading Parameters ────────────────────────────────────────────────────────
DEFAULT_SLIPPAGE_BPS=100                      # [OPTIONAL]
MIN_TRADE_SIZE_SOL=0.01                       # [OPTIONAL]
MAX_TRADE_SIZE_SOL=1.0                        # [OPTIONAL]
TIP_PERCENTAGE=0.001                          # [OPTIONAL] Jito tip as a fraction of trade value
RETRY_ATTEMPTS=3                              # [OPTIONAL]
RETRY_DELAY_MS=1000                           # [OPTIONAL]

# ─── Execution ─────────────────────────────────────────────────────────────────
EXECUTION_WORKERS=4                           # [OPTIONAL] parallel order execution workers
MAX_CONCURRENT_ORDERS=10                      # [OPTIONAL]
ORDER_TIMEOUT_SECONDS=30                      # [OPTIONAL]

# ─── Sniper Strategy ───────────────────────────────────────────────────────────
# Automatically submit buy orders when new tokens are discovered via WebSocket.
AUTO_SNIPE=false                              # [OPTIONAL] set true to enable automatic sniping
SNIPE_AMOUNT_SOL=0.05                         # [OPTIONAL] SOL per auto-snipe order

# ─── Monitoring ────────────────────────────────────────────────────────────────
LOG_LEVEL=info                                # [OPTIONAL] trace | debug | info | warn | error
SLACK_WEBHOOK_URL=                            # [OPTIONAL] Slack webhook URL for trade alerts
