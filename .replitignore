# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# ── Rust build artifacts (~6 GB) ──────────────────────────────────────────────
rust-engine/target/

# ── Replit internal directories ────────────────────────────────────────────────
.local
.cache
.upm

# ── Git history (~700 MB) ─────────────────────────────────────────────────────
.git

# NOTE: .pythonlibs is intentionally NOT excluded.
# It contains both the wrapped python3 interpreter and the strategy engine's
# installed dependencies (fastapi, grpcio, scikit-learn, etc.). Without it,
# the production Express server cannot spawn the Python strategy engine.
# Bytecode caches inside .pythonlibs are still excluded below.

# ── Node.js dependencies (reinstalled during build) ──────────────────────────
**/node_modules
**/.pnpm-store
.pnpm-store

# ── Python bytecode caches ────────────────────────────────────────────────────
**/__pycache__
**/*.pyc
**/*.pyo

# NOTE: artifacts/api-server/dist is intentionally NOT excluded.
# The built dist/ must be present in the deployment image for the server to start.
# artifacts/dashboard/dist is also included since Express serves it statically.

# ── Mockup sandbox build output (dev-only, not deployed) ──────────────────────
artifacts/mockup-sandbox/dist

# ── Miscellaneous dev-only files ─────────────────────────────────────────────
**/*.log
**/*.swp
**/.DS_Store
**/*.edit.toml
tmp
